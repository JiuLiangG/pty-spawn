{
  "name": "pty-spawn",
  "version": "0.4.0",
  "description": "PTY-based bash execution for pi — with headless terminal emulation, persistent sessions, and real-time session observation",
  "keywords": ["pi-package"],
  "bin": {
    "pty-spawn": "./dist/cli/index.js"
  },
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "@xterm/headless": "^5.5.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*",
    "vitest": "^3.0.0"
  }
}
